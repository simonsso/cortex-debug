{
	"name": "cortex-debug-remote",
	"displayName": "cortex-debug-remote",
	"description": "Extension to support VSCode remote developent with Cortex-Debug",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.63.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onDebugResolve:cortex-debug"
	],
	"main": "./dist/extension.js",
	"publisher": "marus25",
	"license": "MIT",
	"extensionKind": [
		"ui"
	],
	"contributes": {
		"commands": [
			{
				"command": "cortex-debug-remote.helloWorld",
				"title": "Hello World"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "webpack",
		"watch": "webpack --watch",
		"package": "webpack --mode production --devtool hidden-source-map",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "npm run compile-tests && npm run compile && npm run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@types/command-exists": "^1.2.3",
		"@types/glob": "^8.1.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^18.19.0",
		"@types/vscode": "^1.89.0",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"@typescript-eslint/parser": "^7.0.0",
		"@vscode/test-electron": "^2.4.0",
		"eslint": "^9.0.0",
		"glob": "^7.2.0",
		"mocha": "^11.7.5",
		"ts-loader": "^9.5.0",
		"typescript": "^5.3.0",
		"webpack": "^5.90.0",
		"webpack-cli": "^6.0.0"
	},
	"dependencies": {
		"command-exists": "^1.2.9",
		"vscode-jsonrpc": "^8.2.1"
	},
	"overrides": {
		"serialize-javascript": "^7.0.5",
		"cross-spawn": "^7.0.6"
	}
}
